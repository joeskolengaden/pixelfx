{
	"repoName": "pixelfx",
	"name": "Pixel FX (color order / hue / framerate)",
	"author": "joeskolengaden",
	"description": "Single ChannelData modifier plugin: mirror, hue-shift wave, saturation, color order, brightness/dimmer, sparkle, strobe and framerate, each independently toggleable over its own channel range. RGBW-aware. Never alters test patterns.",
	"homeURL": "https://github.com/joeskolengaden/pixelfx",
	"srcURL": "https://github.com/joeskolengaden/pixelfx.git",
	"bugURL": "https://github.com/joeskolengaden/pixelfx/issues",
	"allowUpdates": 1,
	"hasSettingsPage": 1,
	"pluginType": "channelData",
	"pipelineStage": "modifyChannelData",
	"appSchemaVersion": 2,
	"settingsFile": "config/plugin.pixelfx",
	"settingsSchema": [
		{
			"key": "enabled",
			"label": "Plugin enabled",
			"type": "bool",
			"default": false,
			"group": "general",
			"appliesLive": true,
			"help": "Master on/off for all functions."
		},
		{
			"key": "onlyWhenPlaying",
			"label": "Only while a sequence is playing",
			"type": "bool",
			"default": true,
			"group": "general",
			"appliesLive": true,
			"help": "Only modify during sequence playback. Test patterns are never modified."
		},
		{
			"key": "channelsPerPixel",
			"label": "Channels per pixel",
			"type": "enum",
			"default": "3",
			"options": [
				"3",
				"4"
			],
			"group": "general",
			"appliesLive": true,
			"help": "3 = RGB, 4 = RGBW (white channel is preserved by hue/color order)."
		},
		{
			"key": "mr_enabled",
			"label": "Mirror enabled",
			"type": "bool",
			"default": false,
			"group": "mirror",
			"appliesLive": true
		},
		{
			"key": "mr_startChannel",
			"label": "Mirror: start channel",
			"type": "int",
			"default": 1,
			"min": 1,
			"max": 1048576,
			"step": 1,
			"group": "mirror",
			"appliesLive": true
		},
		{
			"key": "mr_channelCount",
			"label": "Mirror: channel count",
			"type": "int",
			"default": 1500,
			"min": 0,
			"max": 1048576,
			"step": 3,
			"group": "mirror",
			"appliesLive": true
		},
		{
			"key": "mr_mode",
			"label": "Mode",
			"type": "enum",
			"default": "reverse",
			"options": [
				"reverse",
				"mirror"
			],
			"group": "mirror",
			"appliesLive": true,
			"help": "reverse = flip the whole range; mirror = reflect the first half onto the second."
		},
		{
			"key": "hs_enabled",
			"label": "Hue shift enabled",
			"type": "bool",
			"default": false,
			"group": "hueshift",
			"appliesLive": true
		},
		{
			"key": "hs_startChannel",
			"label": "Hue: start channel",
			"type": "int",
			"default": 1,
			"min": 1,
			"max": 1048576,
			"step": 1,
			"group": "hueshift",
			"appliesLive": true
		},
		{
			"key": "hs_channelCount",
			"label": "Hue: channel count",
			"type": "int",
			"default": 1500,
			"min": 0,
			"max": 1048576,
			"step": 3,
			"group": "hueshift",
			"appliesLive": true
		},
		{
			"key": "hs_hueWave",
			"label": "Hue wave",
			"type": "enum",
			"default": "off",
			"options": [
				"off",
				"sine",
				"triangle",
				"sawtooth",
				"square"
			],
			"group": "hueshift",
			"appliesLive": true
		},
		{
			"key": "hs_huePeriodMs",
			"label": "Hue period",
			"type": "int",
			"default": 5000,
			"min": 1,
			"max": 600000,
			"step": 100,
			"unit": "ms",
			"group": "hueshift",
			"appliesLive": true
		},
		{
			"key": "hs_hueDepthDeg",
			"label": "Hue depth",
			"type": "int",
			"default": 360,
			"min": 0,
			"max": 360,
			"step": 1,
			"unit": "deg",
			"group": "hueshift",
			"appliesLive": true,
			"widget": "slider"
		},
		{
			"key": "hs_huePhasePerChannel",
			"label": "Hue phase / LED",
			"type": "float",
			"default": 0,
			"min": -45,
			"max": 45,
			"step": 0.1,
			"unit": "deg",
			"group": "hueshift",
			"appliesLive": true,
			"help": "Per-pixel offset for a traveling rainbow."
		},
		{
			"key": "sa_enabled",
			"label": "Saturation enabled",
			"type": "bool",
			"default": false,
			"group": "saturation",
			"appliesLive": true
		},
		{
			"key": "sa_startChannel",
			"label": "Saturation: start channel",
			"type": "int",
			"default": 1,
			"min": 1,
			"max": 1048576,
			"step": 1,
			"group": "saturation",
			"appliesLive": true
		},
		{
			"key": "sa_channelCount",
			"label": "Saturation: channel count",
			"type": "int",
			"default": 1500,
			"min": 0,
			"max": 1048576,
			"step": 3,
			"group": "saturation",
			"appliesLive": true
		},
		{
			"key": "sa_level",
			"label": "Saturation",
			"type": "int",
			"default": 100,
			"min": 0,
			"max": 300,
			"step": 5,
			"unit": "%",
			"group": "saturation",
			"appliesLive": true,
			"help": "100 = unchanged, 0 = grayscale, >100 = boosted.",
			"widget": "slider"
		},
		{
			"key": "co_enabled",
			"label": "Color order enabled",
			"type": "bool",
			"default": false,
			"group": "colororder",
			"appliesLive": true
		},
		{
			"key": "co_startChannel",
			"label": "Color: start channel",
			"type": "int",
			"default": 1,
			"min": 1,
			"max": 1048576,
			"step": 1,
			"group": "colororder",
			"appliesLive": true
		},
		{
			"key": "co_channelCount",
			"label": "Color: channel count",
			"type": "int",
			"default": 1500,
			"min": 0,
			"max": 1048576,
			"step": 3,
			"group": "colororder",
			"appliesLive": true
		},
		{
			"key": "co_colorOrder",
			"label": "Color order",
			"type": "enum",
			"default": "RGB",
			"options": [
				"RGB",
				"RBG",
				"GRB",
				"GBR",
				"BRG",
				"BGR"
			],
			"group": "colororder",
			"appliesLive": true
		},
		{
			"key": "br_enabled",
			"label": "Brightness enabled",
			"type": "bool",
			"default": false,
			"group": "brightness",
			"appliesLive": true
		},
		{
			"key": "br_startChannel",
			"label": "Brightness: start channel",
			"type": "int",
			"default": 1,
			"min": 1,
			"max": 1048576,
			"step": 1,
			"group": "brightness",
			"appliesLive": true
		},
		{
			"key": "br_channelCount",
			"label": "Brightness: channel count",
			"type": "int",
			"default": 1500,
			"min": 0,
			"max": 1048576,
			"step": 1,
			"group": "brightness",
			"appliesLive": true
		},
		{
			"key": "br_level",
			"label": "Brightness",
			"type": "int",
			"default": 100,
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"group": "brightness",
			"appliesLive": true,
			"help": "Dimmer / power limiter. 100 = full.",
			"widget": "slider"
		},
		{
			"key": "sp_enabled",
			"label": "Sparkle enabled",
			"type": "bool",
			"default": false,
			"group": "sparkle",
			"appliesLive": true
		},
		{
			"key": "sp_startChannel",
			"label": "Sparkle: start channel",
			"type": "int",
			"default": 1,
			"min": 1,
			"max": 1048576,
			"step": 1,
			"group": "sparkle",
			"appliesLive": true
		},
		{
			"key": "sp_channelCount",
			"label": "Sparkle: channel count",
			"type": "int",
			"default": 1500,
			"min": 0,
			"max": 1048576,
			"step": 3,
			"group": "sparkle",
			"appliesLive": true
		},
		{
			"key": "sp_density",
			"label": "Density",
			"type": "int",
			"default": 10,
			"min": 0,
			"max": 100,
			"step": 1,
			"group": "sparkle",
			"appliesLive": true,
			"help": "How often new white twinkles spawn.",
			"widget": "slider"
		},
		{
			"key": "sp_decayMs",
			"label": "Decay",
			"type": "int",
			"default": 400,
			"min": 1,
			"max": 5000,
			"step": 50,
			"unit": "ms",
			"group": "sparkle",
			"appliesLive": true,
			"help": "How fast each twinkle fades out."
		},
		{
			"key": "st_enabled",
			"label": "Strobe enabled",
			"type": "bool",
			"default": false,
			"group": "strobe",
			"appliesLive": true
		},
		{
			"key": "st_startChannel",
			"label": "Strobe: start channel",
			"type": "int",
			"default": 1,
			"min": 1,
			"max": 1048576,
			"step": 1,
			"group": "strobe",
			"appliesLive": true
		},
		{
			"key": "st_channelCount",
			"label": "Strobe: channel count",
			"type": "int",
			"default": 1500,
			"min": 0,
			"max": 1048576,
			"step": 1,
			"group": "strobe",
			"appliesLive": true
		},
		{
			"key": "st_periodMs",
			"label": "Period",
			"type": "int",
			"default": 200,
			"min": 10,
			"max": 10000,
			"step": 10,
			"unit": "ms",
			"group": "strobe",
			"appliesLive": true
		},
		{
			"key": "st_duty",
			"label": "On time",
			"type": "int",
			"default": 50,
			"min": 1,
			"max": 99,
			"step": 1,
			"unit": "%",
			"group": "strobe",
			"appliesLive": true,
			"help": "Percent of each period the pixels are on.",
			"widget": "slider"
		},
		{
			"key": "fr_enabled",
			"label": "Framerate enabled",
			"type": "bool",
			"default": false,
			"group": "framerate",
			"appliesLive": true
		},
		{
			"key": "fr_startChannel",
			"label": "Framerate: start channel",
			"type": "int",
			"default": 1,
			"min": 1,
			"max": 1048576,
			"step": 1,
			"group": "framerate",
			"appliesLive": true
		},
		{
			"key": "fr_channelCount",
			"label": "Framerate: channel count",
			"type": "int",
			"default": 1500,
			"min": 0,
			"max": 1048576,
			"step": 1,
			"group": "framerate",
			"appliesLive": true
		},
		{
			"key": "fr_fps",
			"label": "Framerate",
			"type": "int",
			"default": 20,
			"min": 0,
			"max": 60,
			"step": 1,
			"unit": "fps",
			"group": "framerate",
			"appliesLive": true,
			"help": "Hold frames to this rate. 0 = disabled.",
			"widget": "slider"
		}
	],
	"versions": [
		{
			"minFPPVersion": "5.0",
			"maxFPPVersion": "0",
			"branch": "main",
			"sha": ""
		}
	]
}
